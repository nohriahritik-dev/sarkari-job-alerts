# Leave empty in local dev — the Vite proxy forwards /api/* to the API server on port 8080.
# On Vercel, set this to your Render API URL, e.g.:
#   VITE_API_URL=https://sarkari-job-alert-api.onrender.com
VITE_API_URL=

# Optional: override the Vite dev server port (default 5173)
# PORT=5173

# Optional: override the API server port the proxy targets (default 8080)
# API_PORT=8080
